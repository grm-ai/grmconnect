{
  "manifest_version": 3,
  "name": "GRM Connect Connector",
  "version": "2.0.0",
  "description": "Connect LinkedIn + scrape search results inside your real Chrome.",
  "permissions": ["cookies", "scripting", "tabs", "storage", "debugger"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://grmconnect-production.up.railway.app/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.vercel.app/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["linkedin_scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GRM Connect"
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
